# ══════════════════════════════════════════════════════════════════════════════
#  Priya Bot — Configuration
#  Copy this file to .env and fill in your values.
#  All settings live here — no other config files to touch.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
# Port the HTTP server listens on (Pterodactyl assigns this automatically)
PORT=8080

# Set to "production" on your server
NODE_ENV=production

# Base URL path for the dashboard (keep as "/" unless behind a sub-path proxy)
BASE_PATH=/

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (MongoDB Atlas free tier works fine)
# Format: mongodb+srv://user:password@cluster.mongodb.net/priya?retryWrites=true
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/priya?retryWrites=true&w=majority

# ── Discord Bot ───────────────────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications → Your App
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-application-client-id-here

# !! REQUIRED FOR PORTAL LOGIN !!
# Found at: discord.com/developers/applications → Your App → OAuth2 → Client Secret
# Click "Reset Secret" if you've never seen it before.
DISCORD_CLIENT_SECRET=your-discord-client-secret-here

# ── Portal / User Login (Discord OAuth2) ──────────────────────────────────────
# The EXACT redirect URI you added in Discord Developer Portal.
# Go to: discord.com/developers/applications → Your App → OAuth2 → Redirects
# Add this URL there (replace with your actual domain):
#   https://YOUR-DOMAIN.com/api/auth/discord/callback
#
# Examples:
#   Pterodactyl:  https://us-2.galactichosting.net:30014/api/auth/discord/callback
#   Render.com:   https://mommy-wl7k.onrender.com/api/auth/discord/callback
#   Local dev:    http://localhost:8080/api/auth/discord/callback
DISCORD_REDIRECT_URI=https://YOUR-DOMAIN.com/api/auth/discord/callback

# ── Your Discord User ID ──────────────────────────────────────────────────────
# For owner-only dashboard features
OWNER_DISCORD_ID=your-discord-user-id-here

# ── Dashboard Auth ────────────────────────────────────────────────────────────
# Password to log into the owner dashboard (choose something strong)
DASHBOARD_SECRET=change-me-to-a-strong-password

# Secret used to sign JWT tokens (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-secret-string

# ── AI API Keys ───────────────────────────────────────────────────────────────
# Add at least one. The bot will rotate between keys automatically.
# Leave blank if you don't have a key for that provider.

# Groq (fast & free tier available): https://console.groq.com/keys
GROQ_API_KEY_1=

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY_1=

# Nvidia NIM: https://build.nvidia.com/
NVIDIA_API_KEY_1=

# ── Optional ──────────────────────────────────────────────────────────────────
# Public URL of your bot's website — shown in !help command so users can click the portal link
# Example: https://mommy-wl7k.onrender.com  or  https://us-2.galactichosting.net:30014
SITE_URL=https://YOUR-DOMAIN.com

# Path to pre-built dashboard files (leave blank to use default)
# DASHBOARD_STATIC_PATH=./artifacts/dashboard/dist/public
